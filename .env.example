# ══════════════════════════════════════════════════════════════
#  Variables de entorno — Facturador ARCA en Railway
#  Copiar este archivo como .env para desarrollo local
#  En Railway: configurar en Settings → Variables
# ══════════════════════════════════════════════════════════════

# ── Notion ────────────────────────────────────────────────────
# Token de integración (desde notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la base de datos "Registro de Facturas Emitidas"
# Se obtiene de la URL de Notion: notion.so/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx?v=...
#                                          ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
NOTION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ARCA / Certificados ───────────────────────────────────────
# CUIT del monotributista (sin guiones)
CUIT_EMISOR=20250886234

# Número de punto de venta habilitado en ARCA
PUNTO_VENTA=3

# Fecha de inicio de actividades (para el PDF)
INICIO_ACT=01/07/2019

# Certificado digital en base64 (ver instrucciones abajo)
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("facturador_arca.key"))
# Linux/Mac:  base64 -w 0 facturador_arca.key
CERT_KEY_B64=xxxxxxxx...

# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("facturador_arca.crt"))
# Linux/Mac:  base64 -w 0 facturador_arca.crt
CERT_CRT_B64=xxxxxxxx...

# ── Configuración del daemon ──────────────────────────────────
# Intervalo de polling en milisegundos (default: 30000 = 30 segundos)
POLL_INTERVAL_MS=30000

# Ambiente: dejar vacío para PRODUCCIÓN, poner "homologacion" para pruebas
AMBIENTE=
